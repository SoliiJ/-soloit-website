---
import BaseLayout from '../layouts/BaseLayout.astro';

/* 
  WRZUCANIE WŁASNYCH ZDJĘĆ:
  1. Wygeneruj obrazki w AI (np. Midjourney, DALL-E, Leonardo)
  2. Zapisz je w folderze: public/images/portfolio/
  3. Zamień nazwy plików poniżej lub podmień pliki w folderze
  4. Idealne wymiary: 1200x900px (proportion 4:3)
  5. Po zmianie: git add -A && git commit -m "nowe zdjecia portfolio" && git push
*/

const projects = [
  {
    title: 'Salon Kosmetyczny "Glow"',
    category: 'Strona firmowa · WordPress',
    tags: 'Elementor · Rezerwacje · SEO lokalne',
    image: '/images/portfolio/salon-kosmetyczny.jpg',
  },
  {
    title: 'Sklep Budowlany "Dach-Mur"',
    category: 'WooCommerce · Sklep online',
    tags: 'WooCommerce · Płatności · 200+ produktów',
    image: '/images/portfolio/sklep-budowlany.jpg',
  },
  {
    title: 'Kancelaria Prawna Kowalski',
    category: 'Landing page · WordPress',
    tags: 'Konwersja · Formularz · Blog',
    image: '/images/portfolio/kancelaria-prawna.jpg',
  },
  {
    title: 'Pizzeria "La Mamma"',
    category: 'Strona firmowa · Menu online',
    tags: 'WordPress · Menu · Zamówienia',
    image: '/images/portfolio/pizzeria.jpg',
  },
  {
    title: 'Firma Transportowa "Speed-Trans"',
    category: 'Strona korporacyjna · WordPress',
    tags: 'Elementor · Galeria · Kalkulator',
    image: '/images/portfolio/firma-transportowa.jpg',
  },
  {
    title: 'Studio Fotograficzne "Focus"',
    category: 'Portfolio · Galeria',
    tags: 'WordPress · Lightbox · Rezerwacje',
    image: '/images/portfolio/studio-fotograficzne.jpg',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: projects.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.title,
    description: `${p.category} – ${p.tags}`
  }))
};
---

<BaseLayout
  title="Portfolio – Realizacje Stron WWW | SoloIT"
  description="Zobacz wybrane realizacje stron internetowych: WordPress, WooCommerce, landing pages. Portfolio dewelopera z Rudy Śląskiej."
  schema={schema}
  breadcrumbs={[
    { name: 'Strona główna', item: '/' },
    { name: 'Portfolio', item: '/portfolio/' }
  ]}
>
  <section class="pt-32 pb-16 hero-mesh">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="pill mb-4 inline-flex">Portfolio</span>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-cream mb-6 max-w-3xl">
        Twoja strona może <span class="gradient-text">tak wyglądać</span>
      </h1>
      <p class="text-cream-muted text-lg max-w-2xl">
        Poniżej znajdziesz przykłady stron, które projektuję dla moich klientów. 
        Każda z nich jest dopasowana do branży, responsywna i zoptymalizowana pod wyszukiwarki.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-cream-dim/40 font-mono text-center mb-8">
        *Prezentowane projekty mają charakter poglądowy i ilustrują możliwości stylistyczne oraz funkcjonalne realizacji.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, i) => (
          <div class="reveal group" style={`transition-delay: ${i * 100}ms`}>
            <div class="card-glow rounded-xl bg-surface border border-gold/10 hover:border-gold/30 overflow-hidden transition-all">
              <div class="aspect-[4/3] bg-void-light overflow-hidden relative">
                <img 
                  src={project.image} 
                  alt={`Podgląd strony ${project.title}`}
                  class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  width="800"
                  height="600"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-void/60 via-transparent to-transparent pointer-events-none" />
              </div>
              <div class="p-5">
                <h3 class="font-display font-semibold text-lg text-cream mb-1 group-hover:text-gold transition-colors">{project.title}</h3>
                <p class="text-sm text-cream-dim mb-1.5">{project.category}</p>
                <p class="text-xs text-cream-dim/60 font-mono">{project.tags}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-void-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-2xl text-cream mb-4">Chcesz podobną stronę?</h2>
      <p class="text-cream-muted mb-8">Opisz swoją branżę, a ja przygotuję projekt dopasowany do Twoich potrzeb – od wizytówki po rozbudowany sklep.</p>
      <a href="mailto:soloitkontakt@gmail.com" class="btn-primary">Darmowa wycena</a>
    </div>
  </section>
</BaseLayout>
