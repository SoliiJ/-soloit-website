---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Tworzenie stron internetowych",
  provider: { "@id": "https://soloit.pl/#business" },
  areaServed: { "@type": "Place", name: "Śląsk, Polska" },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Strony internetowe",
    itemListElement: [
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Strona wizytówka WordPress" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Sklep WooCommerce" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Landing page Astro" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Strona korporacyjna" } },
    ]
  }
};

const packages = [
  {
    name: 'Wizytówka',
    price: 'od 1 500 zł',
    desc: 'Idealna dla małych firm i freelancerów',
    features: ['1-3 podstrony', 'WordPress + Elementor', 'Responsywny design', 'Podstawowe SEO', 'Formularz kontaktowy', 'Hosting 1 rok']
  },
  {
    name: 'Biznes',
    price: 'od 3 500 zł',
    desc: 'Rozbudowana strona z blogiem',
    features: ['Do 10 podstron', 'WordPress + Elementor', 'Blog / aktualności', 'Zaawansowane SEO', 'Integracja z Google Maps', 'Wsparcie 30 dni'],
    popular: true
  },
  {
    name: 'Sklep',
    price: 'od 6 000 zł',
    desc: 'WooCommerce z płatnościami online',
    features: ['WooCommerce', 'Płatności online', 'Import produktów', 'Integracja kurierzy', 'Panel zarządzania', 'Wsparcie 60 dni']
  }
];
---

<BaseLayout
  title="Tworzenie Stron Internetowych Ruda Śląska | WordPress & WooCommerce"
  description="Projektowanie i tworzenie stron internetowych na WordPress i WooCommerce. Ruda Śląska, Mikołów, Gliwice. Responsywne, szybkie i zoptymalizowane pod SEO."
  schema={schema}
  breadcrumbs={[
    { name: 'Strona główna', item: '/' },
    { name: 'Usługi', item: '/uslugi/' },
    { name: 'Strony internetowe', item: '/uslugi/strony-internetowe/' }
  ]}
>
  <section class="pt-32 pb-16 hero-mesh">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="pill mb-4 inline-flex">Strony WWW</span>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-cream mb-6 max-w-3xl">
        Tworzenie stron <span class="gradient-text">internetowych</span> na Śląsku
      </h1>
      <p class="text-cream-muted text-lg max-w-2xl mb-8">
        Projektuję nowoczesne strony na WordPress i WooCommerce dla firm z Rudy Śląskiej, 
        Mikołowa, Gliwic i całego Śląska. Każda strona jest responsywna, szybka i przyjazna Google.
      </p>
      <a href="mailto:kontakt@soloit.pl" class="btn-primary">Bezpłatna wycena</a>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="pill mb-4 inline-flex">Proces</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-cream mb-4">Jak to działa?</h2>
        <p class="text-cream-muted">Prosty, transparentny proces od pierwszego maila do wdrożenia.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { num: '01', title: 'Rozmowa', desc: 'Opisujesz czego potrzebujesz. Bez żargonu, po ludzku.' },
          { num: '02', title: 'Wycena', desc: 'W ciągu 24h otrzymujesz szczegółową wycenę i harmonogram.' },
          { num: '03', title: 'Realizacja', desc: 'Koduję stronę, pokazuję preview, wprowadzam poprawki.' },
          { num: '04', title: 'Wdrożenie', desc: 'Strona wisi na hostingu, Google ją indeksuje, zaczynasz zarabiać.' },
        ].map((step, i) => (
          <div class="reveal relative" style={`transition-delay: ${i * 100}ms`}>
            <span class="font-display font-bold text-5xl text-gold/10 absolute -top-4 -left-2">{step.num}</span>
            <div class="relative pt-6">
              <h3 class="font-display font-semibold text-xl text-cream mb-2">{step.title}</h3>
              <p class="text-cream-dim text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-24 sm:py-32 bg-void-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="pill mb-4 inline-flex">Cennik</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-cream mb-4">Przejrzyste ceny</h2>
        <p class="text-cream-muted">Bez ukrytych kosztów. Płacisz za efekt, nie za godziny.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {packages.map((pkg, i) => (
          <div class={`reveal rounded-xl p-8 border ${pkg.popular ? 'border-gold/30 bg-surface-raised relative' : 'border-gold/10 bg-surface'}`} style={`transition-delay: ${i * 100}ms`}>
            {pkg.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 pill bg-gold text-void text-xs font-bold">Najpopularniejsze</span>
            )}
            <h3 class="font-display font-bold text-xl text-cream mb-1">{pkg.name}</h3>
            <p class="text-cream-dim text-sm mb-4">{pkg.desc}</p>
            <div class="font-display font-bold text-3xl text-gold mb-6">{pkg.price}</div>
            <ul class="space-y-3 mb-8">
              {pkg.features.map(f => (
                <li class="flex items-center gap-2 text-sm text-cream-muted">
                  <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="mailto:kontakt@soloit.pl?subject=Wycena%20-%20{pkg.name}" class={`block text-center w-full py-3 rounded-lg font-display font-semibold text-sm transition-all ${pkg.popular ? 'bg-gold text-void hover:bg-gold-light' : 'border border-gold/20 text-cream hover:border-gold hover:text-gold'}`}>
              Wybieram
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local SEO -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-cream mb-8">Tworzenie stron w Twojej okolicy</h2>
      <div class="flex flex-wrap gap-3">
        {['strony internetowe Ruda Śląska', 'strony www Mikołów', 'tworzenie stron Gliwice', 'strony internetowe Katowice', 'strony www Zabrze', 'projektowanie stron Bytom', 'strony Tychy', 'tworzenie stron Chorzów', 'strony internetowe Sosnowiec', 'strony www Bielsko-Biała'].map(tag => (
          <span class="px-4 py-2 rounded-full bg-surface border border-gold/10 text-sm text-cream-muted">{tag}</span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
