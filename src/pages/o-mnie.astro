---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: {
    "@type": "Person",
    name: "SoloIT",
    jobTitle: "Freelance Developer & IT Specialist",
    url: "https://soloit.pl/o-mnie/",
    worksFor: { "@id": "https://soloit.pl/#business" },
    knowsAbout: ["Tworzenie stron internetowych", "WordPress", "Automatyzacja", "Python", "Serwis IT"]
  }
};
---

<BaseLayout
  title="O mnie – Freelance Developer z Rudy Śląskiej | SoloIT"
  description="Kim jestem? Freelance deweloper i specjalista IT z Rudy Śląskiej. Tworzę strony WWW, automatyzuję procesy i naprawiam technologię na Śląsku."
  schema={schema}
  breadcrumbs={[
    { name: 'Strona główna', item: '/' },
    { name: 'O mnie', item: '/o-mnie/' }
  ]}
>
  <section class="pt-32 pb-16 hero-mesh">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="pill mb-4 inline-flex">O mnie</span>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-cream mb-6 max-w-3xl">
        Jeden człowiek. <span class="gradient-text">Pełna odpowiedzialność.</span>
      </h1>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="reveal space-y-6">
          <p class="text-lg text-cream leading-relaxed">
            Cześć! Jestem SoloIT – freelance deweloper i specjalista IT z <strong class="text-gold">Rudy Śląskiej</strong>. 
            Od 7 lat pomagam małym firmom i osobom prywatnym wykorzystywać technologię do zarabiania więcej i pracowania mądrzej.
          </p>
          <p class="text-cream-muted leading-relaxed">
            Nie jestem agencją z pięcioma pośrednikami. Jeden człowiek, pełna odpowiedzialność. 
            Znam się zarówno na kodzie, jak i na designie oraz SEO – dlatego strony, które tworzę, 
            nie tylko ładnie wyglądają, ale przede wszystkim <strong class="text-cream">przyciągają klientów</strong>.
          </p>
          <p class="text-cream-muted leading-relaxed">
            Specjalizuję się w tworzeniu stron na WordPress i WooCommerce, pisaniu skryptów automatyzujących 
            w Pythonie oraz serwisie sprzętu komputerowego z dojazdem do klienta.
          </p>

          <div class="pt-6">
            <h2 class="font-display font-semibold text-xl text-cream mb-4">Dlaczego warto ze mną współpracować?</h2>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                <span class="text-cream-muted">Bezpośredni kontakt – rozmawiasz z osobą, która koduje</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                <span class="text-cream-muted">Ceny bez ukrytych kosztów – wycena przed startem</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                <span class="text-cream-muted">Znam lokalny rynek – Ruda Śląska, Mikołów, Gliwice i okolice</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                <span class="text-cream-muted">Wsparcie po wdrożeniu – nie zostawiam klientów samym sobie</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="reveal reveal-delay-1 space-y-6">
          <div class="bg-surface rounded-xl border border-gold/10 p-8">
            <h3 class="font-display font-semibold text-lg text-cream mb-4">Technologie</h3>
            <div class="flex flex-wrap gap-2">
              {['WordPress', 'WooCommerce', 'Astro', 'Tailwind CSS', 'Python', 'JavaScript', 'Elementor', 'SEO', 'Linux', 'Node.js'].map(t => (
                <span class="px-3 py-1.5 rounded-full bg-void-light border border-gold/10 text-sm text-cream-muted">{t}</span>
              ))}
            </div>
          </div>

          <div class="bg-surface rounded-xl border border-gold/10 p-8">
            <h3 class="font-display font-semibold text-lg text-cream mb-4">Obszar działania</h3>
            <p class="text-cream-muted mb-4">
              Serwis z dojazdem do klienta oraz usługi zdalne na terenie całego województwa śląskiego:
            </p>
            <div class="flex flex-wrap gap-2">
              {['Ruda Śląska', 'Mikołów', 'Gliwice', 'Katowice', 'Zabrze', 'Bytom', 'Tychy', 'Chorzów', 'Sosnowiec', 'Dąbrowa Górnicza', 'Bielsko-Biała', 'Pszczyna', 'Czechowice-Dziedzice', 'Żory', 'Jastrzębie-Zdrój', 'Rybnik', 'Wodzisław Śląski'].map(city => (
                <span class="text-sm text-cream-dim">{city}</span>
              ))}
            </div>
          </div>

          <div class="bg-surface rounded-xl border border-gold/10 p-8">
            <h3 class="font-display font-semibold text-lg text-cream mb-2">Kontakt</h3>
            <div class="space-y-3">
              <a href="mailto:kontakt@soloit.pl" class="flex items-center gap-3 text-cream-muted hover:text-gold transition-colors">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                kontakt@soloit.pl
              </a>
              <a href="tel:+48663821462" class="flex items-center gap-3 text-cream-muted hover:text-gold transition-colors">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                663 821 462
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
